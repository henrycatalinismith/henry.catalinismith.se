#!/usr/bin/env ruby

require "nokogiri"
require "net/http"
require "uri"
require "fileutils"
require "cgi"

url = ARGV[0]
abort "Usage: #{$0} <url>" unless url

uri = URI.parse(url)
res = Net::HTTP.get_response(uri)

unless res.is_a?(Net::HTTPSuccess)
  abort "Failed to fetch URL: #{res.code} #{res.message}"
end

html = res.body

doc = Nokogiri::HTML(html)
title = doc.at('title')&.text
abort "Couldn't extract title" unless title
title = CGI.unescapeHTML(title.gsub(/\s+/, ' ').strip)

slug = title.downcase
  .gsub(/[^a-z0-9\s-]/, '')
  .strip
  .gsub(/\s+/, '-')

date = Time.now.strftime("%Y-%m-%d")

dir = "_bookmarks"
filename = File.join(dir, "#{date}-#{slug}.md")

content = <<~MD
---
title: #{title}
tags: [bookmarks]
external_url: #{url}
---
MD

File.write(filename, content)

exec("hx", filename)
