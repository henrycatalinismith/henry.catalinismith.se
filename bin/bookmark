#!/usr/bin/env ruby

require './lib/bookmark'
require "nokogiri"
require "net/http"
require "uri"
require "fileutils"
require "cgi"
require 'yaml'

url = ARGV[0]
abort "Usage: #{$0} <url>" unless url

metadata = fetch_metadata(url)
frontmatter = create_frontmatter(metadata)

slug = metadata["title"].downcase
  .gsub(/[^a-z0-9\s-]/, '')
  .strip
  .gsub(/\s+/, '-')

date = Time.now.strftime("%Y-%m-%d")

dir = "_bookmarks"
filename = File.join(dir, "#{date}-#{slug}.md")

content = "#{frontmatter.to_yaml}---".strip.chomp

File.write(filename, content)

exec("hx", filename)
